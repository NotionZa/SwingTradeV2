# Anthropic
ANTHROPIC_API_KEY=

# Market data & sentiment APIs
NEWSAPI_KEY=
# Optional alias: NEWS_API_KEY=
# Optional: pipe-separated broad NewsAPI queries for macro/general news (OR within each segment):
# NEWSAPI_MACRO_QUERIES=Federal Reserve OR rates|semiconductor OR AI|stock market OR earnings
FINNHUB_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SwingTradeV2/0.1

# Discord webhooks (treat as secrets)
DISCORD_WEBHOOK_DAILY_BRIEFING=
DISCORD_WEBHOOK_MACRO_TECH=
DISCORD_WEBHOOK_EARNINGS_FLOW=
DISCORD_WEBHOOK_MARKET_NEWS=
DISCORD_WEBHOOK_WATCHLIST=
DISCORD_WEBHOOK_TRADE_SETUPS=
DISCORD_WEBHOOK_RISK_MANAGEMENT=

# Discord bot (Gateway) for watchlist slash commands
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Optional: comma-separated Snowflake IDs
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_ROLE_IDS=

# Models (override if Anthropic slugs change)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-7

# Paths (defaults: repo-root config/)
SWINGTRADE_CONFIG_DIR=

# Optional: override directory for agent system prompts (default: repo-root prompts/)
SWINGTRADE_PROMPTS_DIR=
